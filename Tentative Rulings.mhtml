.floatLeft { float: left; }

.floatRight { float: right; }

.png { }

.cleaner { clear: both; }

.clear5, .tabClear { clear: both; height: 5px; }

.clear10 { clear: both; height: 10px; }

body { margin: 0px; font-size: 0.75em; line-height: 150%; font-family: Aria=
l, Helvetica, sans-serif; color: rgb(85, 85, 85); background: url("img/comm=
on/bg-body.gif") center center repeat-y; }

